# ==============================================================================
# Smart Ambulance System - Backend Environment Variables Template
# ==============================================================================

# Required Firebase Client variables for signature verification and auth REST API fallback
FIREBASE_API_KEY="your-firebase-api-key"
FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
FIREBASE_APP_ID="your-firebase-app-id"

# Vite compatibility fallback overrides:
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
VITE_FIREBASE_APP_ID="your-firebase-app-id"

# Backend options
NODE_ENV="development"
PORT=5000
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
SKIP_RATE_LIMIT=true
TEST_PASSWORD="your-secure-test-password"
