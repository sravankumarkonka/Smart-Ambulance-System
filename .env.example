# ==============================================================================
# Smart Ambulance System - Environment Variables Configuration Template
# ==============================================================================
#
# Copy this file to '.env' (in the root directory) and fill in the actual values.
# Do NOT commit the '.env' file or any other credential files to Git.

# ------------------------------------------------------------------------------
# 1. FRONTEND CONFIGURATION (Vite)
# ------------------------------------------------------------------------------
# Firebase Client SDK Configuration (Required for React frontend app)
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_CLIENT_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
VITE_FIREBASE_APP_ID="your-firebase-app-id"

# ------------------------------------------------------------------------------
# 2. BACKEND CONFIGURATION (Express)
# ------------------------------------------------------------------------------
# Node Environment (development | production)
NODE_ENV="development"

# Server Port
PORT=5000

# Firebase Admin SDK Configuration
# In development, you can use the client-based fallback (hasAdmin = false).
# For production token verification, provide the file path to your Service Account JSON key
# or paste the raw JSON string content of the key.
FIREBASE_SERVICE_ACCOUNT_KEY="path/to/serviceAccountKey.json"

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# ------------------------------------------------------------------------------
# 3. END-TO-END TEST CONFIGURATION (Selenium & DAST)
# ------------------------------------------------------------------------------
# Password used by E2E test account bootstrap
TEST_PASSWORD="your-secure-test-password"
